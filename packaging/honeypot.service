[Unit]
Description=Rust Honeypot
Documentation=file:/etc/honeypot/README.md
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/lib/honeypot
ExecStart=/usr/local/bin/honeypot --config /etc/honeypot/config.toml
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576

[Install]
WantedBy=multi-user.target
